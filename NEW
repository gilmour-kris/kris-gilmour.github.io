  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --cream: #faf7f2;
      --warm-white: #fff9f3;
      --sand: #e8ddd0;
      --tan: #c9b99a;
      --brown: #8b6f4e;
      --dark-brown: #4a3728;
      --charcoal: #2c2420;
      --accent: #b07d4f;
      --accent-light: #d4a574;
      --text: #3a2e28;
      --text-muted: #7a6a5e;
    }

    html { scroll-behavior: smooth; }

    body {
      font-family: 'DM Sans', sans-serif;
      background-color: var(--cream);
      color: var(--text);
      line-height: 1.7;
      overflow-x: hidden;
    }

    /* NAV */
    nav {
      position: fixed; top: 0; left: 0; right: 0; z-index: 100;
      display: flex; justify-content: space-between; align-items: center;
      padding: 1.2rem 5%;
      background: rgba(250, 247, 242, 0.92);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid var(--sand);
    }
    .nav-logo {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.4rem; font-weight: 600;
      color: var(--dark-brown); letter-spacing: 0.02em;
    }
    .nav-links { display: flex; gap: 2rem; list-style: none; }
    .nav-links a {
      text-decoration: none; font-size: 0.85rem; font-weight: 500;
      letter-spacing: 0.08em; text-transform: uppercase;
      color: var(--text-muted); transition: color 0.2s;
    }
    .nav-links a:hover { color: var(--accent); }

    /* HERO */
    .hero {
      min-height: 100vh; display: flex; align-items: center;
      padding: 8rem 5% 5rem; position: relative;
      background: var(--warm-white); overflow: hidden;
    }
    .hero::before {
      content: ''; position: absolute; top: -100px; right: -100px;
      width: 600px; height: 600px; border-radius: 50%;
      background: radial-gradient(circle, rgba(176,125,79,0.08) 0%, transparent 70%);
    }
    .hero::after {
      content: ''; position: absolute; bottom: -50px; left: -50px;
      width: 400px; height: 400px; border-radius: 50%;
      background: radial-gradient(circle, rgba(201,185,154,0.12) 0%, transparent 70%);
    }
    .hero-inner { max-width: 900px; animation: fadeUp 0.9s ease both; }
    .hero-eyebrow {
      display: inline-block; font-size: 0.8rem; font-weight: 500;
      letter-spacing: 0.2em; text-transform: uppercase; color: var(--accent);
      margin-bottom: 1.2rem; padding: 0.3rem 0.8rem;
      border: 1px solid var(--accent-light); border-radius: 2px;
    }
    .hero h1 {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(3rem, 7vw, 5.5rem); font-weight: 600;
      line-height: 1.05; color: var(--charcoal); margin-bottom: 0.5rem;
    }
    .hero h1 span { color: var(--accent); }
    .hero-title {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(1.2rem, 2.5vw, 1.8rem); font-weight: 400;
      color: var(--brown); margin-bottom: 1.8rem; letter-spacing: 0.03em;
    }
    .hero-desc {
      font-size: 1.05rem; color: var(--text-muted);
      max-width: 620px; margin-bottom: 2.5rem; font-weight: 300;
    }
    .hero-cta { display: flex; gap: 1rem; flex-wrap: wrap; }

    .btn {
      display: inline-block; padding: 0.85rem 2rem; border-radius: 3px;
      font-size: 0.85rem; font-weight: 500; letter-spacing: 0.08em;
      text-transform: uppercase; text-decoration: none; transition: all 0.25s;
    }
    .btn-primary { background: var(--accent); color: #fff; border: 1px solid var(--accent); }
    .btn-primary:hover {
      background: var(--dark-brown); border-color: var(--dark-brown);
      transform: translateY(-2px); box-shadow: 0 8px 24px rgba(74,55,40,0.18);
    }
    .btn-outline { background: transparent; color: var(--dark-brown); border: 1px solid var(--tan); }
    .btn-outline:hover { border-color: var(--accent); color: var(--accent); transform: translateY(-2px); }

    /* SECTIONS */
    section { padding: 6rem 5%; }
    section:nth-child(even) { background: var(--warm-white); }
    .section-inner { max-width: 1000px; margin: 0 auto; }
    .section-label {
      font-size: 0.75rem; font-weight: 500; letter-spacing: 0.2em;
      text-transform: uppercase; color: var(--accent); margin-bottom: 0.6rem;
    }
    .section-title {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(2rem, 4vw, 3rem); font-weight: 600;
      color: var(--charcoal); line-height: 1.2;
    }
    .divider { width: 48px; height: 2px; background: var(--accent); margin: 1rem 0 2.5rem; }

    /* ABOUT */
    .about-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: center; }
    .about-text p { color: var(--text-muted); margin-bottom: 1.2rem; font-size: 1rem; font-weight: 300; }
    .about-stats { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; }
    .stat-card {
      background: var(--cream); border: 1px solid var(--sand);
      padding: 1.5rem; border-radius: 4px; text-align: center;
      transition: transform 0.2s, box-shadow 0.2s;
    }
    .stat-card:hover { transform: translateY(-3px); box-shadow: 0 10px 30px rgba(74,55,40,0.08); }
    .stat-number {
      font-family: 'Cormorant Garamond', serif; font-size: 2.5rem;
      font-weight: 700; color: var(--accent); line-height: 1; margin-bottom: 0.4rem;
    }
    .stat-label { font-size: 0.8rem; color: var(--text-muted); letter-spacing: 0.05em; text-transform: uppercase; }

    /* TIMELINE */
    .timeline { position: relative; padding-left: 2rem; }
    .timeline::before {
      content: ''; position: absolute; left: 0; top: 8px; bottom: 0;
      width: 1px; background: var(--sand);
    }
    .timeline-item { position: relative; margin-bottom: 3rem; padding-left: 1.5rem; }
    .timeline-item::before {
      content: ''; position: absolute; left: -2.4rem; top: 8px;
      width: 10px; height: 10px; border-radius: 50%;
      background: var(--accent); border: 2px solid var(--cream);
      box-shadow: 0 0 0 3px var(--sand);
    }
    .timeline-date {
      font-size: 0.78rem; font-weight: 500; letter-spacing: 0.1em;
      text-transform: uppercase; color: var(--accent); margin-bottom: 0.3rem;
    }
    .timeline-role {
      font-family: 'Cormorant Garamond', serif; font-size: 1.4rem;
      font-weight: 600; color: var(--charcoal); margin-bottom: 0.15rem;
    }
    .timeline-company { font-size: 0.9rem; color: var(--brown); font-weight: 500; margin-bottom: 0.8rem; }
    .timeline-desc { font-size: 0.95rem; color: var(--text-muted); font-weight: 300; }
    .timeline-desc ul { padding-left: 1.2rem; margin-top: 0.4rem; }
    .timeline-desc li { margin-bottom: 0.4rem; }

    /* ACHIEVEMENTS */
    .achievements { background: var(--dark-brown) !important; padding: 5rem 5%; }
    .achievements .section-label { color: var(--accent-light); }
    .achievements .section-title { color: var(--cream); }
    .achievements .divider { background: var(--accent-light); }
    .achievements-grid {
      display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1.2rem;
    }
    .achievement-card {
      border: 1px solid rgba(201,185,154,0.2); padding: 1.4rem 1.6rem;
      border-radius: 4px; color: var(--tan); font-size: 0.92rem; font-weight: 300;
      display: flex; gap: 0.8rem; align-items: flex-start;
      transition: background 0.2s, border-color 0.2s;
    }
    .achievement-card:hover { background: rgba(176,125,79,0.12); border-color: var(--accent); }
    .achievement-card strong { color: var(--cream); }
    .achievement-icon { color: var(--accent-light); font-size: 1rem; margin-top: 0.15rem; flex-shrink: 0; }

    /* SKILLS */
    .skills-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1.5rem; }
    .skill-category {
      background: var(--cream); border: 1px solid var(--sand);
      padding: 1.8rem; border-radius: 4px; transition: transform 0.2s, box-shadow 0.2s;
    }
    .skill-category:hover { transform: translateY(-3px); box-shadow: 0 10px 30px rgba(74,55,40,0.08); }
    .skill-cat-title {
      font-family: 'Cormorant Garamond', serif; font-size: 1.15rem; font-weight: 600;
      color: var(--dark-brown); margin-bottom: 1rem; padding-bottom: 0.6rem;
      border-bottom: 1px solid var(--sand);
    }
    .skill-tags { display: flex; flex-wrap: wrap; gap: 0.5rem; }
    .skill-tag {
      background: var(--warm-white); border: 1px solid var(--tan);
      color: var(--brown); padding: 0.3rem 0.75rem; border-radius: 2px;
      font-size: 0.82rem; transition: all 0.2s;
    }
    .skill-tag:hover { background: var(--accent); color: #fff; border-color: var(--accent); }

    /* EDUCATION */
    .edu-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 1.5rem; }
    .edu-card {
      background: var(--cream); border: 1px solid var(--sand);
      padding: 2rem; border-radius: 4px; transition: transform 0.2s, box-shadow 0.2s;
    }
    .edu-card:hover { transform: translateY(-3px); box-shadow: 0 10px 30px rgba(74,55,40,0.08); }
    .edu-year { font-size: 0.78rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--accent); margin-bottom: 0.5rem; }
    .edu-degree { font-family: 'Cormorant Garamond', serif; font-size: 1.25rem; font-weight: 600; color: var(--charcoal); margin-bottom: 0.25rem; }
    .edu-school { font-size: 0.9rem; color: var(--brown); font-weight: 500; }
    .edu-detail { font-size: 0.88rem; color: var(--text-muted); margin-top: 0.6rem; font-weight: 300; }

    /* CONTACT */
    #contact { background: var(--charcoal) !important; color: var(--cream); }
    #contact .section-label { color: var(--accent-light); }
    #contact .section-title { color: var(--cream); }
    #contact .divider { background: var(--accent-light); }
    .contact-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: start; }
    .contact-intro { font-size: 1rem; color: var(--tan); font-weight: 300; margin-bottom: 2rem; }
    .contact-links { display: flex; flex-direction: column; gap: 1rem; }
    .contact-link {
      display: flex; align-items: center; gap: 1rem; text-decoration: none;
      padding: 1rem 1.2rem; border: 1px solid rgba(201,185,154,0.2);
      border-radius: 4px; color: var(--cream); transition: all 0.25s;
    }
    .contact-link:hover { background: rgba(176,125,79,0.15); border-color: var(--accent); transform: translateX(4px); }
    .contact-link-icon {
      width: 36px; height: 36px; background: rgba(176,125,79,0.2);
      border-radius: 50%; display: flex; align-items: center; justify-content: center;
      font-size: 1rem; flex-shrink: 0;
    }
    .contact-link-text strong { display: block; font-size: 0.85rem; font-weight: 500; letter-spacing: 0.05em; }
    .contact-link-text span { font-size: 0.8rem; color: var(--tan); }
    .contact-message h3 {
      font-family: 'Cormorant Garamond', serif; font-size: 1.6rem;
      font-weight: 600; color: var(--cream); margin-bottom: 1rem;
    }
    .contact-message p { color: var(--tan); font-weight: 300; font-size: 0.95rem; margin-bottom: 1.5rem; }

    /* FOOTER */
    footer {
      background: var(--charcoal); border-top: 1px solid rgba(201,185,154,0.1);
      text-align: center; padding: 1.5rem 5%;
      font-size: 0.8rem; color: var(--text-muted);
    }

    /* ANIMATIONS */
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(24px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    .fade-up { opacity: 0; transform: translateY(24px); transition: opacity 0.7s ease, transform 0.7s ease; }
    .fade-up.visible { opacity: 1; transform: translateY(0); }

    @media (max-width: 768px) {
      .about-grid, .contact-grid { grid-template-columns: 1fr; gap: 2.5rem; }
      .nav-links { display: none; }
      .hero { padding-top: 6rem; }
    }
  </style>
</head>
